{
  "name": "电子衣橱",
  "version": "0.1.0",
  "description": "数字化衣橱管理应用",
  "productName": "电子衣橱",
  "bundledWebRuntime": false,
  "弁 Nishio: "",
  "appId": "com.wardrobe.digital",
  "webDir": "../dist",
  "server": {
    "url": "http://localhost:8080",
    "cleartext": true,
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1a1a2e",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#1a1a2e",
      "overlaysWebView": false
    },
    "CapacitorHttp": {
      "enabled": true
    }
  },
  "android": {
    "backgroundColor": "#1a1a2e",
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "minSdkVersion": 22,
    "versionCode": 1,
    "versionName": "0.1.0"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#1a1a2e",
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "minimumVersion": "13.0"
  }
}
